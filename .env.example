# LLM Provider (only ollama is supported)
LLM_PROVIDER=ollama

# Ollama Configuration (local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Whisper Configuration
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Agent Configuration
MAX_EXTRACTION_ITERATIONS=2
MAX_TRANSCRIPTION_ATTEMPTS=1
QUALITY_THRESHOLD=0.8

# Output
OUTPUT_DIR=./output
LOG_LEVEL=INFO
